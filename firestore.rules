rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Strict Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for security verification
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      return isSignedIn() &&
             request.auth.token.email.toLowerCase() == "ricardo.vaca@academicos.udg.mx" &&
             request.auth.token.email_verified == true;
    }

    // --- RULES FOR STUDENTS COLLECTION ---

    match /students/{studentEmail} {
      // Allows individual document retrieval (safe as studentEmail document ID acts as a private key)
      allow get: if true;
      
      // Allows selective queries for verification with custom limits, blocking mass client-side scraper queries
      allow list: if isTeacher() || (request.query.limit <= 5);
      
      // Teacher exclusively manages student roster registrations
      allow write: if isTeacher();
    }

    // --- RULES FOR GROUPS AND SUB-COLLECTIONS ---

    match /groups/{groupId} {
      // Allow reading metadata of groups/CRNs so students can fetch descriptions, titles, and rubric configurations
      allow read: if true;
      allow write: if isTeacher();

      // Attendance registers
      match /attendance/{date} {
        allow read: if true;
        allow write: if isTeacher();
      }

      // Deliverable items and dynamic criteria structures
      match /grade_items/{itemId} {
        allow read: if true;
        allow write: if isTeacher();
      }

      // Individual grades mapped by studentEmail
      match /student_grades/{studentEmail} {
        allow get: if true;
        allow list: if isTeacher() || (request.query.limit <= 5);
        allow write: if isTeacher();
      }
    }

  }
}
